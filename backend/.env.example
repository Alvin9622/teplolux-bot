# ============================================================================
# Teplolux AI CRM Assistant — Environment Configuration
# ----------------------------------------------------------------------------
# Copy this file to `.env` and fill in real values.
# The application validates every variable on boot (see src/config/env.validation.ts)
# and REFUSES TO START if any value is missing or invalid.
# ============================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
NODE_ENV=development
# Port the HTTP server binds to
PORT=3000
# Global route prefix for the REST API (health/webhook live outside business APIs)
API_PREFIX=api
# Public base URL of this service (used when registering the Telegram webhook)
APP_BASE_URL=https://crm.teplolux.example.com
# Comma-separated list of allowed CORS origins, or `*` for all
CORS_ORIGINS=*

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
# One of: error | warn | info | http | debug | verbose
LOG_LEVEL=info
# Write rotating log files to disk in addition to the console
LOG_TO_FILE=true
# Directory for rotating log files
LOG_DIR=logs

# ---------------------------------------------------------------------------
# PostgreSQL / Prisma
# ---------------------------------------------------------------------------
# Full connection string used by Prisma
DATABASE_URL=postgresql://teplolux:teplolux@localhost:5432/teplolux_crm?schema=public
# Individual components — consumed by docker-compose for the postgres container
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=teplolux
POSTGRES_PASSWORD=teplolux
POSTGRES_DB=teplolux_crm

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# Logical database index
REDIS_DB=0

# ---------------------------------------------------------------------------
# Authentication (JWT) — used by future admin/dealer portals
# ---------------------------------------------------------------------------
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
JWT_EXPIRES_IN=1d

# ---------------------------------------------------------------------------
# Telegram Bot
# ---------------------------------------------------------------------------
# Bot token issued by @BotFather
TELEGRAM_BOT_TOKEN=123456789:AAExampleTokenReplaceMe
# Secret token Telegram echoes in the X-Telegram-Bot-Api-Secret-Token header.
# Must be 1-256 chars of A-Z a-z 0-9 _ -
TELEGRAM_WEBHOOK_SECRET=replace-with-a-long-random-secret
# Path segment of the webhook endpoint (combined with APP_BASE_URL)
TELEGRAM_WEBHOOK_PATH=webhook/telegram
# Automatically register the webhook with Telegram on application startup
TELEGRAM_SET_WEBHOOK_ON_STARTUP=false
# Group/channel chat id that receives every submitted lead in real time.
# Example: -1001234567890 (supergroup/channel) or @channelusername.
# Leave empty to disable Telegram delivery (leads are then only logged).
# The bot must be a member (group) or admin (channel) of this chat.
TELEGRAM_LEAD_CHAT_ID=

# ---------------------------------------------------------------------------
# Rate limiting (global throttler)
# ---------------------------------------------------------------------------
# Time window in milliseconds
RATE_LIMIT_TTL_MS=60000
# Max requests per window per client
RATE_LIMIT_MAX=120

# ---------------------------------------------------------------------------
# Future integrations (architecture placeholders — not active yet)
# ---------------------------------------------------------------------------
# AMOCRM_BASE_URL=
# AMOCRM_CLIENT_ID=
# AMOCRM_CLIENT_SECRET=
# AMOCRM_REDIRECT_URI=
