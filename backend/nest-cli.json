{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "plugins": ["@nestjs/swagger"],
    "assets": [
      { "include": "i18n/locales/**/*.json", "watchAssets": true },
      { "include": "modules/telegram/knowledge/articles/**/*.md", "watchAssets": true }
    ]
  }
}
